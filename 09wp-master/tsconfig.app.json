{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "components.d.ts",
    "auto-imports.d.ts",
    "vite-env.d.ts"
  ],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "jsxImportSource": "react",

    "types": ["vite-plugin-app-loading/client", "element-plus/global", "react", "react-dom"],

    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
